# PHP News Portal - Git Ignore

# Replit-specific (not needed for cPanel deployment)
.replit
replit.md
.agents/
artifacts/
lib/
scripts/
attached_assets/
node_modules/
.vite/
*.tsbuildinfo

# Database files
data/*.db
data/*.sqlite
data/*.sqlite3

# Uploaded files (if not committed)
assets/uploads/*
!assets/uploads/.gitkeep

# IDEs and editors
.idea/
.vscode/
*.sublime-workspace
*.sublime-project
.settings/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Backup files
*.bak
*.backup
*.zip
*~

# Composer
/vendor/

# Local configuration overrides (keep db.config.example if exists)
/db.config.local.php
